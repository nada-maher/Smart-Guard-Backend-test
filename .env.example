# Smart Guard Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# SMTP Configuration (for email notifications)
# ============================================
# Gmail: smtp.gmail.com
# Outlook: smtp.outlook.com
# Yahoo: smtp.mail.yahoo.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Your email address that will send notifications
SENDER_EMAIL=your_email@gmail.com

# For Gmail: Generate App Password in Google Account settings
# For others: Use your email password
SENDER_PASSWORD=your_app_password_here

# ============================================
# Moderator Emails (receives signup notifications)
# ============================================
# Separate multiple emails with commas if needed
MODERATOR_EMAIL_1=admin@smartguard.com
MODERATOR_EMAIL_2=moderator@smartguard.com

